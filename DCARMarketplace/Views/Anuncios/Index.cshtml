@model IEnumerable<DCARMarketplace.Models.Anuncio>

@{
    ViewData["Title"] = "Veículos à Venda";
}

<div class="container mt-4">
    <h2 class="mb-4">Veículos Disponíveis</h2>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@(string.IsNullOrEmpty(item.Fotos) ? "https://via.placeholder.com/300x200?text=Sem+Foto" : item.Fotos)"
                         class="card-img-top" alt="Foto do veículo" style="height: 200px; object-fit: cover;">

                    <div class="card-body">
                        <h5 class="card-title">@item.Titulo</h5>
                        <p class="card-text text-muted">
                            @(item.Carro?.Modelo?.Marca?.Nome ?? "Marca N/A") @(item.Carro?.Modelo?.Nome ?? "")
                        </p>
                        <h4 class="text-danger fw-bold">@item.Preco.ToString("C")</h4>

                        <ul class="list-unstyled mt-3 mb-4">
                            <li><i class="bi bi-calendar"></i> Ano: @(item.Carro?.Ano)</li>
                            <li><i class="bi bi-speedometer2"></i> Km: @(item.Carro?.Quilometragem)</li>
                            <li><i class="bi bi-geo-alt"></i> @item.Localizacao</li>
                        </ul>

                        <div class="d-grid">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-danger">Ver Detalhes</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Não existem anúncios disponíveis neste momento.
        </div>
    }
</div>