@model DCARMarketplace.Models.Anuncio

@{
    ViewData["Title"] = "Detalhes do Veículo";
}

<div class="container mt-5">
    <a asp-action="Index" class="btn btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left"></i> Voltar à Lista
    </a>

    <div class="row">
        <div class="col-md-8">
            <img src="@(string.IsNullOrEmpty(Model.Fotos) ? "https://via.placeholder.com/800x600?text=Sem+Foto" : Model.Fotos)"
                 class="img-fluid rounded shadow" alt="Foto do carro" style="width: 100%; object-fit: cover;">

            <div class="mt-4 p-4 bg-light rounded">
                <h4>Sobre este veículo</h4>
                <p>@Model.Descricao</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="card-title">@Model.Titulo</h3>
                    <h2 class="text-danger fw-bold my-3">@Model.Preco.ToString("C")</h2>

                    <div class="d-grid gap-2">
                        <button class="btn btn-danger btn-lg">Contactar Vendedor</button>
                        <button class="btn btn-outline-dark">Reservar Agora</button>
                    </div>

                    <hr class="my-4">

                    <h5 class="mb-3">Destaques</h5>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="border rounded p-2 text-center">
                                <small class="text-muted d-block">Quilómetros</small>
                                <strong>@Model.Carro?.Quilometragem km</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-2 text-center">
                                <small class="text-muted d-block">Combustível</small>
                                <strong>@(Model.Carro?.Combustivel?.Tipo ?? "N/A")</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-2 text-center">
                                <small class="text-muted d-block">Ano</small>
                                <strong>@Model.Carro?.Ano</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-2 text-center">
                                <small class="text-muted d-block">Caixa</small>
                                <strong>@Model.Carro?.Caixa</strong>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <small class="text-muted"><i class="bi bi-geo-alt-fill"></i> Localização:</small>
                        <p class="fw-bold">@Model.Localizacao</p>

                        <small class="text-muted"><i class="bi bi-person-fill"></i> Vendido por:</small>
                        <p class="fw-bold">@Model.Vendedor?.Nome</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>