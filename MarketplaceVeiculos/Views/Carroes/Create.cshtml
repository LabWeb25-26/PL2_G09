@model MarketplaceVeiculos.Models.Carro

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Carro</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="VIN" class="control-label"></label>
                <input asp-for="VIN" class="form-control" />
                <span asp-validation-for="VIN" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="matricula" class="control-label"></label>
                <input asp-for="matricula" class="form-control" />
                <span asp-validation-for="matricula" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ano" class="control-label"></label>
                <input asp-for="ano" class="form-control" />
                <span asp-validation-for="ano" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="quilometragem" class="control-label"></label>
                <input asp-for="quilometragem" class="form-control" />
                <span asp-validation-for="quilometragem" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="caixa" class="control-label"></label>
                <input asp-for="caixa" class="form-control" />
                <span asp-validation-for="caixa" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="id_modelo" class="control-label">Modelo</label>
                <select asp-for="id_modelo" class="form-control" asp-items="ViewBag.id_modelo"></select>
            </div>

            <div class="form-group">
                <label asp-for="id_combustivel" class="control-label">Combustível</label>
                <select asp-for="id_combustivel" class="form-control" asp-items="ViewBag.id_combustivel"></select>
            </div>

            <br />
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}