@model Dcar.Models.Anuncio

@{
    ViewData["Title"] = "Criar Anúncio";
}

<h1>Criar Novo Anúncio</h1>

<h4>Preencha os dados</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="IdVendedor" class="control-label">Vendedor</label>
                <select asp-for="IdVendedor" class="form-control" asp-items="(SelectList)ViewBag.IdVendedor"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdCarro" class="control-label">Carro (Matrícula)</label>
                <select asp-for="IdCarro" class="form-control" asp-items="(SelectList)ViewBag.IdCarro"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Titulo" class="control-label">Título do Anúncio</label>
                <input asp-for="Titulo" class="form-control" placeholder="Ex: BMW Série 3 como novo" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Descricao" class="control-label">Descrição Detalhada</label>
                <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descricao" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="DataInicio" class="control-label">Data de Início</label>
                    <input asp-for="DataInicio" class="form-control" type="date" />
                    <span asp-validation-for="DataInicio" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="DataFim" class="control-label">Data de Fim (Opcional)</label>
                    <input asp-for="DataFim" class="form-control" type="date" />
                    <span asp-validation-for="DataFim" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Localizacao" class="control-label">Localização</label>
                <input asp-for="Localizacao" class="form-control" />
                <span asp-validation-for="Localizacao" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Preco" class="control-label">Preço (€)</label>
                <input asp-for="Preco" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Preco" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estado" class="control-label">Estado</label>
                <select asp-for="Estado" class="form-control">
                    <option value="ativo">Ativo</option>
                    <option value="reservado">Reservado</option>
                    <option value="vendido">Vendido</option>
                    <option value="pausado">Pausado</option>
                </select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Carregar Foto</label>
                <input type="file" name="ficheiroFoto" class="form-control" accept=".jpg,.jpeg,.png" />
                <span asp-validation-for="Fotos" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Publicar Anúncio" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}