@model Dcar.Models.Modelo

@{
    ViewData["Title"] = "Criar Modelo";
}

<h1>Criar Novo Modelo</h1>

<h4>Modelo</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="IdMarca" class="control-label">Marca</label>
                <select asp-for="IdMarca" class="form-control" asp-items="ViewBag.IdMarca"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NomeModelo" class="control-label">Nome do Modelo</label>
                <input asp-for="NomeModelo" class="form-control" placeholder="Ex: Série 3, Clio, Ibiza..." />
                <span asp-validation-for="NomeModelo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Gravar Modelo" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}