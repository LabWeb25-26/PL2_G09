@model IEnumerable<Dcar.Models.Anuncio>
@{
    ViewData["Title"] = "Home";
}

<div class="bg-dark text-white py-5 mb-5" style="background-image: url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?q=80&w=1920'); background-size: cover; background-position: center; position: relative;">
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.6);"></div>

    <div class="container position-relative py-5">
        <div class="text-center mb-4">
            <h1 class="display-4 fw-bold">Encontra o teu próximo carro</h1>
            <p class="lead">Milhares de carros usados e novos ao melhor preço.</p>
        </div>

        <div class="card p-4 shadow-lg border-0" style="max-width: 800px; margin: 0 auto; background: rgba(255,255,255,0.95);">
            <form asp-controller="Anuncios" asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="searchString" class="form-control form-control-lg" placeholder="Marca ou Modelo...">
                </div>
                <div class="col-md-4">
                    <select class="form-select form-select-lg">
                        <option selected>Qualquer Preço</option>
                        <option value="5000">Até 5.000€</option>
                        <option value="15000">Até 15.000€</option>
                        <option value="30000">Até 30.000€</option>
                    </select>
                </div>
                <div class="col-md-4 d-grid">
                    <button type="submit" class="btn btn-danger btn-lg fw-bold">Pesquisar 🔍</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container">
    <h3 class="mb-4 border-bottom pb-2">✨ Últimas Novidades</h3>

    <div class="row row-cols-1 row-cols-md-4 g-4">
        @foreach (var item in Model.Take(4)) // Mostra só os 4 mais recentes
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div style="height: 150px; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(item.Fotos))
                        {
                            <img src="@item.Fotos" class="card-img-top" style="width: 100%; height: 100%; object-fit: cover;">
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/300x200" class="card-img-top">
                        }
                    </div>
                    <div class="card-body p-3">
                        <h6 class="card-title fw-bold text-truncate">@item.Titulo</h6>
                        <div class="text-danger fw-bold">@item.Preco.ToString("N0") €</div>
                        <small class="text-muted">@item.Localizacao</small>
                    </div>
                    <a asp-controller="Anuncios" asp-action="Details" asp-route-id="@item.IdAnuncio" class="stretched-link"></a>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-5 mb-5">
        <a asp-controller="Anuncios" asp-action="Index" class="btn btn-outline-dark btn-lg">Ver todos os anúncios</a>
    </div>
</div>