@model Dcar.Models.Carro

@{
    ViewData["Title"] = "Adicionar Carro";
}

<h1>Adicionar Novo Carro</h1>

<h4>Detalhes da Viatura</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Vin" class="control-label">Número VIN</label>
                <input asp-for="Vin" class="form-control" />
                <span asp-validation-for="Vin" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Matricula" class="control-label">Matrícula</label>
                <input asp-for="Matricula" class="form-control" />
                <span asp-validation-for="Matricula" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Ano" class="control-label">Ano</label>
                <input asp-for="Ano" class="form-control" type="number" />
                <span asp-validation-for="Ano" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Quilometragem" class="control-label"></label>
                <input asp-for="Quilometragem" class="form-control" type="number" />
                <span asp-validation-for="Quilometragem" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Caixa" class="control-label">Caixa (Manual/Auto)</label>
                <input asp-for="Caixa" class="form-control" />
                <span asp-validation-for="Caixa" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdModelo" class="control-label">Modelo</label>
                <select asp-for="IdModelo" class="form-control" asp-items="ViewBag.IdModelo"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdCombustivel" class="control-label">Combustível</label>
                <select asp-for="IdCombustivel" class="form-control" asp-items="ViewBag.IdCombustivel"></select>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Guardar Carro" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}