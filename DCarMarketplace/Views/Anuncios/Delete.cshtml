@model DCarMarketplace.Models.Anuncio

@{
    ViewData["Title"] = "Eliminar Anúncio";

    // Lógica segura para a imagem
    string primeiraFoto = null;
    if (!string.IsNullOrEmpty(Model.Fotos))
    {
        primeiraFoto = Model.Fotos.Split(';', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
    }
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <div class="card-header bg-danger text-white text-center py-4">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
                    <h3 class="mt-2 fw-bold">Tem a certeza?</h3>
                    <p class="mb-0 opacity-75">Esta ação é irreversível. O anúncio será removido permanentemente.</p>
                </div>

                <div class="card-body p-4 text-center">

                    <div class="mb-4 d-flex justify-content-center">
                        <div class="rounded-3 overflow-hidden shadow-sm border" style="width: 220px; height: 140px; background-color: #f8f9fa;">
                            @if (!string.IsNullOrEmpty(primeiraFoto))
                            {
                                <img src="~/imagens_carros/@primeiraFoto" class="w-100 h-100" style="object-fit: cover;">
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
                                    <i class="bi bi-camera-fill fs-2"></i>
                                </div>
                            }
                        </div>
                    </div>

                    <h4 class="fw-bold text-dark mb-1">@Model.Titulo</h4>

                    <p class="text-muted mb-3">
                        @(Model.Carro?.Modelo?.Marca?.Nome ?? "Marca N/A")
                        @(Model.Carro?.Modelo?.Nome ?? "Modelo N/A") •
                        @(Model.Carro?.Ano)
                    </p>

                    <h3 class="text-danger fw-bold mb-4">@Model.Preco.ToString("N0") €</h3>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold py-3 shadow-sm">
                                <i class="bi bi-trash-fill me-2"></i> ELIMINAR AGORA
                            </button>
                            <a asp-action="MeusAnuncios" class="btn btn-outline-secondary btn-lg py-2">
                                Cancelar
                            </a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>