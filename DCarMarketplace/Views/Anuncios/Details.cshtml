@model DCarMarketplace.Models.Anuncio

@{
    ViewData["Title"] = Model.Titulo;
    // Lógica para separar as imagens
    var listaImagens = Model.Fotos?.Split(';', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
}

<div class="container mt-5 mb-5">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left"></i> Voltar aos resultados
                </a>
            </li>
            <li class="breadcrumb-item text-dark fw-bold active" aria-current="page">@Model.Titulo</li>
        </ol>
    </nav>

    <div class="row">

        <div class="col-lg-8">

            <div class="card border-0 rounded-4 overflow-hidden mb-3 bg-black shadow-sm position-relative">

                @if (Model.Estado != "ativo")
                {
                    <div class="position-absolute top-0 start-0 m-3 z-3">
                        @if (Model.Estado == "reservado")
                        {
                            <span class="badge bg-info text-dark fs-6 shadow"><i class="bi bi-clock"></i> RESERVADO</span>
                        }
                        else if (Model.Estado == "vendido")
                        {

                            <span class="badge bg-danger fs-6 shadow"><i class="bi bi-tag-fill"></i> VENDIDO</span>
                        }
                        else if (Model.Estado == "pausado")
                        {

                            <span class="badge bg-warning text-dark fs-6 shadow"><i class="bi bi-pause-circle"></i> PAUSADO</span>
                        }
                    </div>
                }

                @if (listaImagens.Length > 0)
                {
                    <div id="carroCarousel" class="carousel slide" data-bs-interval="false">
                        <div class="carousel-inner" style="height: 500px; background-color: #000;">
                            @for (int i = 0; i < listaImagens.Length; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "") h-100 text-center">
                                    <img src="~/imagens_carros/@listaImagens[i]" class="h-100 w-auto mw-100" style="object-fit: contain;" alt="Foto @(i + 1)">
                                </div>
                            }
                        </div>

                        @if (listaImagens.Length > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#carroCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon bg-dark rounded-circle p-3 bg-opacity-50" aria-hidden="true"></span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carroCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon bg-dark rounded-circle p-3 bg-opacity-50" aria-hidden="true"></span>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center bg-light text-muted" style="height: 500px;">
                        <div class="text-center">
                            <i class="bi bi-camera-fill" style="font-size: 5rem;"></i>
                            <p class="mt-2">Sem fotos</p>
                        </div>
                    </div>
                }
            </div>

            @if (listaImagens.Length > 1)
            {
                <div class="d-flex gap-2 mb-5 overflow-auto pb-2">
                    @for (int i = 0; i < listaImagens.Length; i++)
                    {
                        <img src="~/imagens_carros/@listaImagens[i]"
                             class="rounded-3 border border-2 cursor-pointer opacity-75 hover-opacity-100"
                             style="width: 100px; height: 70px; object-fit: cover; cursor: pointer; transition: all 0.2s;"
                             onclick="mudarSlide(@i, this)"
                             alt="Miniatura @i">
                    }
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 p-5 mb-5">

                <h3 class="fw-bold mb-4 text-dark">Descrição</h3>
                <p class="text-muted text-break mb-5" style="line-height: 1.8; font-size: 1.05rem; white-space: pre-line;">
                    @Model.Descricao
                </p>

                <div class="details-section-header">
                    <i class="bi bi-info-circle-fill text-primary"></i> Informações Gerais
                </div>

                <div class="detail-row">
                    <span class="detail-label">Marca</span>
                    <span class="detail-value">@Model.Carro.Modelo.Marca.Nome</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Modelo</span>
                    <span class="detail-value">@Model.Carro.Modelo.Nome</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Ano de Registo</span>
                    <span class="detail-value">@Model.Carro.Ano</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Segmento</span>
                    <span class="detail-value">@Model.Carro.Segmento</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Cor</span>
                    <span class="detail-value">@Model.Carro.Cor</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Localização</span>
                    <span class="detail-value">@Model.Localizacao</span>
                </div>

                <div class="details-section-header mt-5">
                    <i class="bi bi-gear-wide-connected text-danger"></i> Dados Técnicos
                </div>

                <div class="detail-row">
                    <span class="detail-label">Quilómetros</span>
                    <span class="detail-value">@Model.Carro.Quilometragem.ToString("N0") km</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Combustível</span>
                    <span class="detail-value">@Model.Carro.Combustivel.Tipo</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Caixa de Velocidades</span>
                    <span class="detail-value">@Model.Carro.Caixa</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Potência</span>
                    <span class="detail-value">@Model.Carro.Potencia cv</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Cilindrada</span>
                    <span class="detail-value">@Model.Carro.Cilindrada cm³</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Nº de Portas</span>
                    <span class="detail-value">@Model.Carro.NumeroPortas</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">VIN (Nº Quadro)</span>
                    <span class="detail-value text-uppercase">@(Model.Carro.VIN ?? "Não disponível")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Referência Anúncio</span>
                    <span class="detail-value">#@Model.Id</span>
                </div>

            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
                <div class="bg-light p-5 text-center" style="background: url('https://maps.googleapis.com/maps/api/staticmap?center=@Model.Localizacao&zoom=13&size=600x300&maptype=roadmap') no-repeat center/cover;">
                    <div class="bg-white d-inline-block p-3 rounded-3 shadow-sm mt-4 mb-4">
                        <i class="bi bi-geo-alt-fill text-danger"></i> <strong>@Model.Localizacao</strong>
                    </div>
                </div>
            </div>

        </div>

        <div class="col-lg-4">
            <div class="price-card sticky-top" style="top: 20px; z-index: 10;">

                <div class="mb-3">
                    <h6 class="text-muted text-uppercase small fw-bold mb-1">@Model.Carro.Modelo.Marca.Nome</h6>
                    <h2 class="fw-bold mb-2">@Model.Carro.Modelo.Nome</h2>
                    <div class="mt-3">
                        <span class="display-5 fw-bold text-danger">@Model.Preco.ToString("N0") €</span>
                    </div>
                </div>

                <hr class="text-muted opacity-25 mb-4">

                <h6 class="fw-bold text-dark mb-3">Destaques</h6>
                <div class="row g-3 text-center small mb-4">

                    <div class="col-4">
                        <div class="p-2 border rounded-3 bg-light h-100">
                            <i class="bi bi-speedometer2 d-block fs-4 mb-1 text-danger"></i>
                            <span class="d-block text-muted" style="font-size: 0.65rem;">QUILÓMETROS</span>
                            <strong>@(Model.Carro.Quilometragem.ToString("N0"))</strong>
                        </div>
                    </div>

                    <div class="col-4">
                        <div class="p-2 border rounded-3 bg-light h-100">
                            <i class="bi bi-fuel-pump d-block fs-4 mb-1 text-danger"></i>
                            <span class="d-block text-muted" style="font-size: 0.65rem;">COMBUSTÍVEL</span>
                            <strong>@Model.Carro.Combustivel.Tipo</strong>
                        </div>
                    </div>

                    <div class="col-4">
                        <div class="p-2 border rounded-3 bg-light h-100">
                            <i class="bi bi-gear-wide d-block fs-4 mb-1 text-danger"></i>
                            <span class="d-block text-muted" style="font-size: 0.65rem;">CAIXA</span>
                            <strong>@Model.Carro.Caixa</strong>
                        </div>
                    </div>

                    <div class="col-4">
                        <div class="p-2 border rounded-3 bg-light h-100">
                            <i class="bi bi-calendar3 d-block fs-4 mb-1 text-danger"></i>
                            <span class="d-block text-muted" style="font-size: 0.65rem;">ANO</span>
                            <strong>@Model.Carro.Ano</strong>
                        </div>
                    </div>

                    <div class="col-4">
                        <div class="p-2 border rounded-3 bg-light h-100">
                            <i class="bi bi-lightning-charge d-block fs-4 mb-1 text-danger"></i>
                            <span class="d-block text-muted" style="font-size: 0.65rem;">POTÊNCIA</span>
                            <strong>@Model.Carro.Potencia cv</strong>
                        </div>
                    </div>

                    <div class="col-4">
                        <div class="p-2 border rounded-3 bg-light h-100">
                            <i class="bi bi-gear d-block fs-4 mb-1 text-danger"></i>
                            <span class="d-block text-muted" style="font-size: 0.65rem;">CILINDRADA</span>
                            <strong>@Model.Carro.Cilindrada cm³</strong>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-3 border">
                    <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 45px; height: 45px; font-size: 1.2rem;">
                        @(Model.Vendedor?.Utilizador?.Nome?.Substring(0, 1).ToUpper() ?? "V")
                    </div>
                    <div>
                        <div class="fw-bold">@(Model.Vendedor?.Utilizador?.Nome ?? "Vendedor Particular")</div>
                        <div class="small text-muted">Membro DCar</div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    @if (User.Identity.IsAuthenticated)
                    {
                        // SE FOR O DONO DO ANÚNCIO OU ADMIN
                        if (User.IsInRole("Administrador") || (Model.Vendedor != null && Model.Vendedor.Utilizador.UserName == User.Identity.Name))
                        {
                            <div class="dropdown">
                                <button class="btn btn-dark w-100 dropdown-toggle py-2 fw-bold" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear-fill me-2"></i> Gerir Estado (@Model.Estado.ToUpper())
                                </button>
                                <ul class="dropdown-menu w-100 shadow">
                                    <li><h6 class="dropdown-header">Definir como:</h6></li>
                                    <li><form asp-action="AtualizarEstado" asp-route-id="@Model.Id" method="post"><input type="hidden" name="novoEstado" value="ativo" /><button class="dropdown-item text-success fw-bold">Ativo</button></form></li>
                                    <li><form asp-action="AtualizarEstado" asp-route-id="@Model.Id" method="post"><input type="hidden" name="novoEstado" value="reservado" /><button class="dropdown-item text-info fw-bold">Reservado</button></form></li>
                                    <li><form asp-action="AtualizarEstado" asp-route-id="@Model.Id" method="post"><input type="hidden" name="novoEstado" value="pausado" /><button class="dropdown-item text-warning fw-bold">Pausado</button></form></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><form asp-action="AtualizarEstado" asp-route-id="@Model.Id" method="post"><input type="hidden" name="novoEstado" value="vendido" /><button class="dropdown-item text-danger fw-bold">Vendido</button></form></li>
                                </ul>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning flex-grow-1 fw-bold text-white">
                                    Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger flex-grow-0">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        }
                        // SE FOR COMPRADOR
                        else if (User.IsInRole("Comprador"))
                        {
                            if (Model.Estado == "ativo")
                            {
                                <a asp-controller="Interacoes" asp-action="Checkout" asp-route-id="@Model.Id" class="btn btn-success btn-lg fw-bold py-3 shadow-sm">
                                    <i class="bi bi-cart-check me-2"></i> Comprar Agora
                                </a>
                                <button class="btn btn-dcar btn-lg fw-bold py-3 shadow-sm" onclick="alert('Mensagem enviada!')">
                                    <i class="bi bi-chat-dots-fill me-2"></i> Enviar Mensagem
                                </button>

                                <button type="button" class="btn btn-outline-dark btn-lg fw-bold py-3" data-bs-toggle="modal" data-bs-target="#modalAcoes">
                                    <i class="bi bi-calendar-check me-2"></i> Agendar / Reserva
                                </button>
                            }
                            else
                            {
                                <div class="alert alert-secondary text-center fw-bold">
                                    Veículo indisponível para compra.
                                </div>
                            }
                        }
                    }
                    else
                    {
                        // SE NÃO ESTIVER LOGADO
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-dcar btn-lg py-3">
                            Login para Contactar
                        </a>
                    }
                </div>

                <div class="text-center mt-3 small text-muted">
                    <i class="bi bi-shield-lock"></i> Compra 100% Segura
                </div>

            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalAcoes" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalLabel">O que deseja fazer?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">

                <div class="card mb-3 border-danger border-2 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold text-danger"><i class="bi bi-bookmark-check-fill me-2"></i> Reservar Agora</h5>
                        <p class="small text-muted mb-3">O veículo ficará reservado para si durante <strong>3 dias</strong>.</p>

                        <form asp-controller="Interacoes" asp-action="Reservar" method="post">
                            <input type="hidden" name="anuncioId" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger w-100 fw-bold">Confirmar Reserva</button>
                        </form>
                    </div>
                </div>

                <div class="text-center text-muted my-2 fw-bold">- OU -</div>

                <div class="card border-0 bg-light mt-3">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3"><i class="bi bi-calendar-event me-2"></i> Agendar Visita</h5>

                        <form asp-controller="Interacoes" asp-action="MarcarVisita" method="post">
                            <input type="hidden" name="anuncioId" value="@Model.Id" />

                            <div class="mb-3">
                                <label class="form-label small text-muted">Escolha a data e hora:</label>
                                <input type="datetime-local" name="dataVisita" class="form-control" required />
                            </div>

                            <button type="submit" class="btn btn-dark w-100 fw-bold">Solicitar Visita</button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    function mudarSlide(index, element) {
        var myCarousel = document.getElementById('carroCarousel');
        var bsCarousel = new bootstrap.Carousel(myCarousel);
        bsCarousel.to(index);

        document.querySelectorAll('img[onclick^="mudarSlide"]').forEach(img => img.style.borderColor = "#dee2e6");
        element.style.borderColor = "#C92525";
    }
</script>