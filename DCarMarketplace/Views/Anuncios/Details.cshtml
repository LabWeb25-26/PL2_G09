@model DCarMarketplace.Models.Anuncio

@{
    ViewData["Title"] = Model.Titulo;

    // --- LÓGICA CRÍTICA: ISTO TEM DE ESTAR AQUI PARA O CARROSSEL FUNCIONAR ---
    // 1. Separa as fotos por ponto e vírgula
    // 2. Se for nulo, cria uma lista vazia para não dar erro
    var listaImagens = Model.Fotos?.Split(';', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
}

<div class="container mt-5 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted fw-bold">
            <i class="bi bi-arrow-left"></i> Voltar aos resultados
        </a>
        <span class="badge bg-light text-dark border px-3 py-2">Referência: #@Model.Id</span>
    </div>

    <div class="row">

        <div class="col-lg-8">

            <div class="card border-0 rounded-4 overflow-hidden mb-4 bg-white shadow-sm">

                @if (listaImagens.Length > 0)
                {
                    <div id="carroCarousel" class="carousel slide" data-bs-interval="false">
                        <div class="carousel-inner" style="height: 500px; background-color: #f0f0f0;">
                            @for (int i = 0; i < listaImagens.Length; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "") h-100">
                                    <img src="~/imagens_carros/@listaImagens[i]" class="d-block w-100 h-100" style="object-fit: cover;" alt="Foto @i">
                                </div>
                            }
                        </div>

                        @if (listaImagens.Length > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#carroCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
                                <span class="visually-hidden">Anterior</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carroCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
                                <span class="visually-hidden">Próximo</span>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center bg-light text-muted" style="height: 500px;">
                        <div class="text-center">
                            <i class="bi bi-camera-fill" style="font-size: 5rem;"></i>
                            <p class="mt-2 fs-5">Sem imagens</p>
                        </div>
                    </div>
                }
            </div>

            @if (listaImagens.Length > 1)
            {
                <div class="d-flex gap-2 mb-5 overflow-auto pb-2">
                    @for (int i = 0; i < listaImagens.Length; i++)
                    {
                        <img src="~/imagens_carros/@listaImagens[i]"
                             class="rounded-3 border cursor-pointer opacity-75 hover-opacity-100"
                             style="width: 100px; height: 70px; object-fit: cover; cursor: pointer; transition: 0.2s;"
                             onclick="mudarSlide(@i)"
                             alt="Miniatura @i">
                    }
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h4 class="fw-bold mb-4">Descrição do Veículo</h4>
                <p class="text-muted text-break" style="line-height: 1.8; white-space: pre-line;">
                    @Model.Descricao
                </p>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="price-card sticky-top" style="top: 20px; z-index: 1;">

                <div class="border-bottom pb-3 mb-3">
                    <h6 class="text-muted text-uppercase small ls-1">@Model.Carro.Modelo.Marca.Nome</h6>
                    <h2 class="fw-bold mb-2">@Model.Carro.Modelo.Nome</h2>
                    <h1 class="text-danger fw-bold mb-0">@Model.Preco.ToString("N0") €</h1>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-person-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold">@(Model.Vendedor?.Utilizador?.Nome ?? "Vendedor")</div>
                        <div class="small text-success"><i class="bi bi-patch-check-fill"></i> Verificado</div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    @if (User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Vendedor") && Model.Vendedor?.Utilizador?.UserName == User.Identity.Name)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning fw-bold text-white">Editar Anúncio</a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Remover</a>
                        }
                        else if (User.IsInRole("Comprador"))
                        {
                            <button class="btn btn-dcar btn-lg shadow-sm">Contactar Vendedor</button>
                            <button class="btn btn-outline-dark btn-lg">Reservar Visita</button>
                        }
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-dcar btn-lg">Login para Contactar</a>
                    }
                </div>

                <hr class="my-4">
                <div class="row g-2 text-center small text-muted">
                    <div class="col-4 mb-3">
                        <i class="bi bi-calendar3 d-block fs-4 mb-1 text-dark"></i> @Model.Carro.Ano
                    </div>
                    <div class="col-4 mb-3">
                        <i class="bi bi-speedometer2 d-block fs-4 mb-1 text-dark"></i> @Model.Carro.Quilometragem km
                    </div>
                    <div class="col-4 mb-3">
                        <i class="bi bi-fuel-pump d-block fs-4 mb-1 text-dark"></i> @Model.Carro.Combustivel.Tipo
                    </div>
                    <div class="col-4">
                        <i class="bi bi-gear-wide d-block fs-4 mb-1 text-dark"></i> @Model.Carro.Caixa
                    </div>
                    <div class="col-8 text-truncate">
                        <i class="bi bi-geo-alt d-block fs-4 mb-1 text-dark"></i> @Model.Localizacao
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    function mudarSlide(index) {
        // Encontra o carrossel
        var myCarousel = document.getElementById('carroCarousel');
        // Usa a API do Bootstrap para ir para o slide X
        var bsCarousel = new bootstrap.Carousel(myCarousel);
        bsCarousel.to(index);
    }
</script>