@model IEnumerable<DCarMarketplace.Models.Anuncio>

@{
    ViewData["Title"] = "Anúncios";
    var favoritosIds = ViewBag.FavoritosIds as List<int> ?? new List<int>();
}

<div class="container mt-4 mb-5">
    <div class="row">

        <div class="col-lg-3 mb-4">
            <div class="filter-sidebar">
                <div class="filter-header">
                    <h5 class="m-0 fw-bold"><i class="bi bi-sliders2"></i> Filtros</h5>
                    <a asp-action="Index" class="filter-reset">Limpar tudo</a>
                </div>

                <form asp-action="Index" method="get">

                    <div class="filter-group">
                        <label class="filter-label">Categoria</label>
                        <select name="segmento" class="filter-select">
                            <option value="Todos">Todas</option>
                            <!option value="SUV" @((string)ViewData["SegmentoAtual"] == "SUV" ? "selected" : "")>SUV</!option>
                            <!option value="Sedan" @((string)ViewData["SegmentoAtual"] == "Sedan" ? "selected" : "")>Sedan</!option>
                            <!option value="Comercial" @((string)ViewData["SegmentoAtual"] == "Comercial" ? "selected" : "")>Comercial</!option>
                            <!option value="Citadino" @((string)ViewData["SegmentoAtual"] == "Citadino" ? "selected" : "")>Citadino</!option>
                            <!option value="Desportivo" @((string)ViewData["SegmentoAtual"] == "Desportivo" ? "selected" : "")>Desportivo</!option>
                            <!option value="Cabrio" @((string)ViewData["SegmentoAtual"] == "Cabrio" ? "selected" : "")>Cabrio</!option>
                            <!option value="Coupe" @((string)ViewData["SegmentoAtual"] == "Coupe" ? "selected" : "")>Coupe</!option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Marcas</label>
                        <select name="marca" id="filterMarca" class="filter-select" onchange="this.form.submit()">
                            <option value="">Todas as marcas</option>
                            @if (ViewBag.ListaMarcas != null)
                            {
                                foreach (var m in ViewBag.ListaMarcas)
                                {
                                    <!option value="@m.Nome" @(m.Nome == (string)ViewData["MarcaAtual"] ? "selected" : "")>@m.Nome</!option>
                                }
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Modelo</label>
                        <select name="modelo" id="filterModelo" class="filter-select text-muted" @(string.IsNullOrEmpty((string)ViewData["MarcaAtual"]) ? "disabled" : "")>
                            <option value="">Todos os modelos</option>
                            @if (ViewData["ModeloAtual"] != null)
                            {
                                <!option value="@ViewData["ModeloAtual"]" selected>@ViewData["ModeloAtual"]</!option>
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Preço (€)</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="filter-input" placeholder="Mín" name="precoMin" value="@ViewData["PrecoMin"]">
                            <input type="number" class="filter-input" placeholder="Máx" name="precoMax" value="@ViewData["PrecoMax"]">
                        </div>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Ano</label>
                        <div class="d-flex gap-2">
                            <select name="anoMin" class="filter-select">
                                <option value="">De</option>
                                @for (int i = 1990; i <= DateTime.Now.Year; i++)
                                {
                                    <!option value="@i" @(ViewData["AnoMin"]?.ToString() == i.ToString() ? "selected" : "")>@i</!option>
                                }
                            </select>
                            <select name="anoMax" class="filter-select">
                                <option value="">Até</option>
                                @for (int i = DateTime.Now.Year; i >= 1990; i--)
                                {
                                    <!option value="@i" @(ViewData["AnoMax"]?.ToString() == i.ToString() ? "selected" : "")>@i</!option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Quilómetros</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="filter-input" placeholder="Mín" name="kmMin" value="@ViewData["KmMin"]">
                            <input type="number" class="filter-input" placeholder="Máx" name="kmMax" value="@ViewData["KmMax"]">
                        </div>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Combustível</label>
                        <select name="combustivel" class="filter-select">
                            <option value="">Todos</option>
                            <!option value="Diesel" @((string)ViewData["CombustivelAtual"] == "Diesel" ? "selected" : "")>Diesel</!option>
                            <!option value="Gasolina" @((string)ViewData["CombustivelAtual"] == "Gasolina" ? "selected" : "")>Gasolina</!option>
                            <!option value="Elétrico" @((string)ViewData["CombustivelAtual"] == "Elétrico" ? "selected" : "")>Elétrico</!option>
                            <!option value="Híbrido" @((string)ViewData["CombustivelAtual"] == "Híbrido" ? "selected" : "")>Híbrido</!option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Caixa</label>
                        <select name="caixa" class="filter-select">
                            <option value="">Todas</option>
                            <!option value="Manual" @((string)ViewData["CaixaAtual"] == "Manual" ? "selected" : "")>Manual</!option>
                            <!option value="Automática" @((string)ViewData["CaixaAtual"] == "Automática" ? "selected" : "")>Automática</!option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Localização</label>
                        <input type="text" class="filter-input" placeholder="Ex: Lisboa" name="localizacao" value="@ViewData["LocalizacaoAtual"]">
                    </div>

                    <button type="submit" class="btn-filter-apply">Aplicar Filtros</button>
                </form>
            </div>
        </div>

        <div class="col-lg-9">

            <div class="top-search-bar">
                <form asp-action="Index" method="get" class="d-flex w-100 align-items-center gap-3">
                    <input type="hidden" name="marca" value="@ViewData["MarcaAtual"]" />
                    <input type="hidden" name="modelo" value="@ViewData["ModeloAtual"]" />
                    <input type="hidden" name="segmento" value="@ViewData["SegmentoAtual"]" />
                    <input type="hidden" name="anoMin" value="@ViewData["AnoMin"]" />
                    <input type="hidden" name="anoMax" value="@ViewData["AnoMax"]" />
                    <input type="hidden" name="precoMin" value="@ViewData["PrecoMin"]" />
                    <input type="hidden" name="precoMax" value="@ViewData["PrecoMax"]" />
                    <input type="hidden" name="kmMin" value="@ViewData["KmMin"]" />
                    <input type="hidden" name="kmMax" value="@ViewData["KmMax"]" />
                    <input type="hidden" name="combustivel" value="@ViewData["CombustivelAtual"]" />
                    <input type="hidden" name="caixa" value="@ViewData["CaixaAtual"]" />
                    <input type="hidden" name="localizacao" value="@ViewData["LocalizacaoAtual"]" />

                    <div class="input-group flex-grow-1">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="pesquisa" class="form-control border-0 bg-transparent shadow-none"
                               placeholder="Pesquisar por marca, modelo, ano..." value="@ViewData["PesquisaAtual"]">
                    </div>

                    <div style="min-width: 180px;">
                        <select name="ordenacao" class="filter-select border-0 bg-transparent fw-bold text-secondary" onchange="this.form.submit()">
                            <!option value="recente" @((string)ViewData["OrdenacaoAtual"] == "recente" ? "selected" : "")>Mais recentes</!option>
                            <!option value="preco_asc" @((string)ViewData["OrdenacaoAtual"] == "preco_asc" ? "selected" : "")>Preço (Menor)</!option>
                            <!option value="preco_desc" @((string)ViewData["OrdenacaoAtual"] == "preco_desc" ? "selected" : "")>Preço (Maior)</!option>
                            <!option value="km_asc" @((string)ViewData["OrdenacaoAtual"] == "km_asc" ? "selected" : "")>Km (Menor)</!option>
                            <!option value="km_desc" @((string)ViewData["OrdenacaoAtual"] == "km_desc" ? "selected" : "")>Km (Maior)</!option>
                        </select>
                    </div>

                    @if (User.IsInRole("Comprador"))
                    {
                        <button type="button" class="btn btn-outline-danger ms-2 border-0" onclick="guardarPesquisa()" title="Guardar esta pesquisa">
                            <i class="bi bi-bookmark-plus fs-5"></i>
                        </button>
                    }
                </form>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var item in Model)
                {
                    bool isFav = favoritosIds.Contains(item.Id);
                    <div class="col">
                        <div class="ad-card h-100 d-flex flex-column">

                            @if (item.Estado != "ativo")
                            {
                                <div class="position-absolute top-0 start-0 m-2 z-3">
                                    @if (item.Estado == "reservado")
                                    {
                                        <span class="badge bg-info text-dark shadow"><i class="bi bi-clock"></i> RESERVADO</span>
                                    }
                                    else if (item.Estado == "vendido")
                                    {
                                        <span class="badge bg-danger shadow"><i class="bi bi-tag-fill"></i> VENDIDO</span>
                                    }
                                    else if (item.Estado == "pausado")
                                    {
                                        <span class="badge bg-warning text-dark shadow"><i class="bi bi-pause-circle"></i> PAUSADO</span>
                                    }
                                </div>
                            }

                            <div class="favorite-icon" onclick="toggleFavorito(@item.Id, this)">
                                <i class="bi @(isFav ? "bi-heart-fill text-danger" : "bi-heart")"></i>
                            </div>

                            <div class="ad-card-img-container">
                                @{
                                    // CORREÇÃO: Lógica segura para List<Foto>
                                    string primeiraFoto = null;
                                    if (item.Fotos != null && item.Fotos.Any())
                                    {
                                        primeiraFoto = item.Fotos.First().FicheiroNome;
                                    }
                                }

                                @if (!string.IsNullOrEmpty(primeiraFoto))
                                {
                                    <img src="~/imagens_carros/@primeiraFoto" class="ad-card-img" alt="@item.Titulo">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 bg-light text-muted"><i class="bi bi-camera-fill fs-1"></i></div>
                                }
                            </div>

                            <div class="ad-card-body d-flex flex-column flex-grow-1">
                                <h5 class="ad-title" title="@item.Titulo">@item.Titulo</h5>
                                <div class="text-muted small mb-2">@(item.Carro.Modelo?.Marca?.Nome) @(item.Carro.Modelo?.Nome)</div>

                                <div class="ad-price">@item.Preco.ToString("N0") €</div>

                                <div class="ad-specs mt-auto">
                                    <div class="ad-spec-item" title="Ano"><i class="bi bi-calendar3"></i> @item.Carro?.Ano</div>
                                    <div class="ad-spec-item" title="Km"><i class="bi bi-speedometer2"></i> @(item.Carro?.Quilometragem) km</div>
                                    <div class="ad-spec-item" title="Combustível"><i class="bi bi-fuel-pump"></i> @item.Carro?.Combustivel?.Tipo</div>
                                    <div class="ad-spec-item" title="Local"><i class="bi bi-geo-alt"></i> @item.Localizacao</div>
                                </div>

                                <div class="mt-3 d-grid gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-details">Ver Detalhes</a>

                                    @if (User.Identity.IsAuthenticated && item.Vendedor?.Utilizador?.UserName == User.Identity.Name)
                                    {
                                        <div class="btn-group shadow-sm" role="group">
                                            <div class="btn-group w-100" role="group">
                                                <button id="btnGroupDrop1" type="button" class="btn btn-outline-dark btn-sm dropdown-toggle fw-bold" data-bs-toggle="dropdown">Estado</button>
                                                <ul class="dropdown-menu">
                                                    <li><form asp-action="AtualizarEstado" asp-route-id="@item.Id" method="post"><input type="hidden" name="novoEstado" value="ativo" /><button class="dropdown-item text-success fw-bold">Ativo</button></form></li>
                                                    <li><form asp-action="AtualizarEstado" asp-route-id="@item.Id" method="post"><input type="hidden" name="novoEstado" value="reservado" /><button class="dropdown-item text-info fw-bold">Reservado</button></form></li>
                                                    <li><form asp-action="AtualizarEstado" asp-route-id="@item.Id" method="post"><input type="hidden" name="novoEstado" value="pausado" /><button class="dropdown-item text-warning fw-bold">Pausado</button></form></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><form asp-action="AtualizarEstado" asp-route-id="@item.Id" method="post"><input type="hidden" name="novoEstado" value="vendido" /><button class="dropdown-item text-danger fw-bold">Vendido</button></form></li>
                                                </ul>
                                            </div>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-white"><i class="bi bi-pencil-fill"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash-fill"></i></a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-light text-center py-5 shadow-sm rounded-4 mt-4">
                    <h4 class="mt-3 fw-bold text-muted">Nenhum veículo encontrado</h4>
                    <a asp-action="Index" class="btn btn-outline-dark mt-2">Limpar Tudo</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // AJAX Modelos
            var marcaAtual = "@ViewData["MarcaAtual"]";
            var modeloAtual = "@ViewData["ModeloAtual"]";

            if (marcaAtual) carregarModelos(marcaAtual, "#filterModelo", modeloAtual);

            function carregarModelos(marca, selectorDropdown, modeloSelecionado = null) {
                var dropdown = $(selectorDropdown);
                $.getJSON("/Anuncios/GetModelosByMarca", { nomeMarca: marca }, function (dados) {
                    dropdown.empty().append('<option value="">Todos os modelos</option>');
                    $.each(dados, function (index, item) {
                        var selected = (item.nome == modeloSelecionado) ? "selected" : "";
                        dropdown.append('<option value="' + item.nome + '" ' + selected + '>' + item.nome + '</option>');
                    });
                    dropdown.prop("disabled", false).removeClass("text-muted");
                });
            }

            // Favoritos
            window.toggleFavorito = function(id, el) {
                 $.post("/Favoritos/Toggle", { anuncioId: id }, function (data) {
                    if (data.success) {
                        var icon = $(el).find("i");
                        if (data.isFavorited) icon.removeClass("bi-heart").addClass("bi-heart-fill text-danger");
                        else icon.removeClass("bi-heart-fill text-danger").addClass("bi-heart");
                        $("#fav-count").text("(" + data.count + ")");
                    } else { window.location.href = "/Identity/Account/Login"; }
                });
            }
        });

        // Guardar Pesquisa (NOVO)
        function guardarPesquisa() {
            var nome = prompt("Dê um nome a esta pesquisa (ex: BMWs baratos):");
            if (nome) {
                var query = window.location.search;
                if (!query) query = "?" + $("form").serialize();
                $.post("/Comprador/SalvarFiltro", { nome: nome, queryUrl: query }, function(res) {
                    if(res.success) alert("Pesquisa guardada nos favoritos!");
                });
            }
        }
    </script>
}