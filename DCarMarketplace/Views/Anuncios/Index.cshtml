@model IEnumerable<DCarMarketplace.Models.Anuncio>

@{
    ViewData["Title"] = "Anúncios";

    // Recuperar lista de IDs favoritos para saber quais corações pintar
    var favoritosIds = ViewBag.FavoritosIds as List<int> ?? new List<int>();
}

<div class="container mt-4 mb-5">
    <div class="row">

        <div class="col-lg-3 mb-4">
            <div class="filter-sidebar">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-sliders"></i> Filtros</h5>
                    <a asp-action="Index" class="text-muted small text-decoration-none">Limpar</a>
                </div>

                <form asp-action="Index" method="get">

                    <div class="filter-group">
                        <label class="filter-label">Categoria</label>
                        <select class="form-select text-muted">
                            <option>Todas as categorias</option>
                            <option>SUV</option>
                            <option>Sedan</option>
                            <option>Comercial</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Marcas</label>
                        <select name="marca" id="filterMarca" class="form-select" onchange="this.form.submit()">
                            <option value="">Todas as marcas</option>
                            @if (ViewBag.ListaMarcas != null)
                            {
                                foreach (var m in ViewBag.ListaMarcas)
                                {
                                    <!option value="@m.Nome" @(m.Nome == (string)ViewData["MarcaAtual"] ? "selected" : "")>@m.Nome</!option>
                                }
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Modelo</label>
                        <select name="modelo" id="filterModelo" class="form-select text-muted" @(string.IsNullOrEmpty((string)ViewData["MarcaAtual"]) ? "disabled" : "")>
                            <option value="">Todos os modelos</option>
                            @if (ViewData["ModeloAtual"] != null)
                            {
                                <!option value="@ViewData["ModeloAtual"]" selected>@ViewData["ModeloAtual"]</!option>
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Preço (€)</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="form-control" placeholder="Mín" name="precoMin">
                            <input type="number" class="form-control" placeholder="Máx" name="precoMax">
                        </div>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Ano</label>
                        <input type="range" class="form-range" min="2000" max="2025" id="anoRange">
                        <div class="d-flex justify-content-between small text-muted">
                            <span>2000</span>
                            <span>2025</span>
                        </div>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">Combustível</label>
                        <select class="form-select">
                            <option>Todos</option>
                            <option>Diesel</option>
                            <option>Gasolina</option>
                            <option>Elétrico</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-details mt-3">Aplicar Filtros</button>
                </form>
            </div>
        </div>

        <div class="col-lg-9">

            <form asp-action="Index" method="get" class="mb-4">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <label class="form-label fw-bold small">Pesquisar</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-3">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" name="pesquisa" class="form-control border-start-0 rounded-end-pill py-2"
                                   placeholder="Marcas, Modelo, Ano..." value="@ViewData["PesquisaAtual"]">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">Ordenar por</label>
                        <select name="ordenacao" class="form-select rounded-pill" onchange="this.form.submit()">
                            <option value="recente" selected="@((string)ViewData["OrdenacaoAtual"] == "recente")">Mais recentes</option>
                            <option value="preco_asc" selected="@((string)ViewData["OrdenacaoAtual"] == "preco_asc")">Preço (Menor)</option>
                            <option value="preco_desc" selected="@((string)ViewData["OrdenacaoAtual"] == "preco_desc")">Preço (Maior)</option>
                        </select>
                    </div>
                </div>
                <input type="hidden" name="marca" value="@ViewData["MarcaAtual"]" />
                <input type="hidden" name="modelo" value="@ViewData["ModeloAtual"]" />
            </form>

            <div class="row">
                @foreach (var item in Model)
                {
                    // Verifica se este carro é favorito do utilizador
                    bool isFav = favoritosIds.Contains(item.Id);

                    <div class="col-md-4 mb-4">
                        <div class="ad-card h-100">

                            <div class="favorite-icon" onclick="toggleFavorito(@item.Id, this)">
                                <i class="bi @(isFav ? "bi-heart-fill text-danger" : "bi-heart")"></i>
                            </div>

                            <div class="ad-card-img-container">
                                @if (!string.IsNullOrEmpty(item.Fotos))
                                {
                                    var primeiraFoto = item.Fotos.Split(';', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();

                                    if (!string.IsNullOrEmpty(primeiraFoto))
                                    {
                                        <img src="~/imagens_carros/@primeiraFoto" class="ad-card-img" alt="@item.Titulo">
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                            <i class="bi bi-camera-fill fs-1"></i>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                        <i class="bi bi-camera-fill fs-1"></i>
                                    </div>
                                }
                            </div>

                            <div class="ad-card-body">
                                <h5 class="ad-title">@item.Titulo</h5>
                                <div class="ad-price">@item.Preco.ToString("N0")€</div>

                                <div class="ad-specs">
                                    <div class="ad-spec-item">
                                        <i class="bi bi-calendar3"></i> <span>@(item.Carro?.Ano)</span>
                                    </div>
                                    <div class="ad-spec-item">
                                        <i class="bi bi-speedometer2"></i> <span>@(item.Carro?.Quilometragem.ToString("N0")) km</span>
                                    </div>
                                    <div class="ad-spec-item">
                                        <i class="bi bi-fuel-pump"></i> <span>@(item.Carro?.Combustivel?.Tipo)</span>
                                    </div>
                                    <div class="ad-spec-item">
                                        <i class="bi bi-geo-alt"></i> <span>@item.Localizacao</span>
                                    </div>
                                </div>

                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-details">Ver Detalhes</a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-light text-center py-5 shadow-sm rounded-4">
                    <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
                    <h4 class="mt-3 fw-bold">Nenhum resultado encontrado</h4>
                    <p class="text-muted">Tente alterar os filtros ou a pesquisa.</p>
                    <a asp-action="Index" class="btn btn-outline-dark mt-2">Limpar Tudo</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // 1. Lógica para a dropdown de Modelos (Filtro Lateral)
            var marcaAtual = "@ViewData["MarcaAtual"]";
            var modeloAtual = "@ViewData["ModeloAtual"]";

            if (marcaAtual) {
                carregarModelos(marcaAtual, "#filterModelo", modeloAtual);
            }

            function carregarModelos(marca, selectorDropdown, modeloSelecionado = null) {
                var dropdown = $(selectorDropdown);

                $.getJSON("/Anuncios/GetModelosByMarca", { nomeMarca: marca }, function (dados) {
                    dropdown.empty();
                    dropdown.append('<option value="">Todos os modelos</option>');

                    $.each(dados, function (index, item) {
                        var selected = (item.nome == modeloSelecionado) ? "selected" : "";
                        dropdown.append('<option value="' + item.nome + '" ' + selected + '>' + item.nome + '</option>');
                    });

                    dropdown.prop("disabled", false);
                    dropdown.removeClass("text-muted");
                });
            }
        });

        // 2. Função de Favoritos (Global)
        function toggleFavorito(anuncioId, element) {
            $.post("/Favoritos/Toggle", { anuncioId: anuncioId }, function (data) {
                if (data.success) {
                    var icon = $(element).find("i");

                    // Troca o ícone visualmente
                    if (data.isFavorited) {
                        icon.removeClass("bi-heart").addClass("bi-heart-fill text-danger");
                    } else {
                        icon.removeClass("bi-heart-fill text-danger").addClass("bi-heart");
                    }

                    // Atualiza o contador na barra de topo (se existir)
                    $("#fav-count").text("(" + data.count + ")");
                } else {
                    // Se não estiver logado ou der erro, manda para o login
                    window.location.href = "/Identity/Account/Login";
                }
            }).fail(function() {
                 window.location.href = "/Identity/Account/Login";
            });
        }
    </script>
}