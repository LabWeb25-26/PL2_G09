@{
    ViewData["Title"] = "Conta em Análise";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">

            <div class="card shadow-sm border-0 p-5 rounded-4">
                <div class="mb-4 text-warning">
                    <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-hourglass-split" viewBox="0 0 16 16">
                        <path d="M2.5 15a.5.5 0 1 1 0-1h1v-1a4.5 4.5 0 0 1 2.557-4.06c.29-.139.443-.377.443-.59v-.7c0-.213-.154-.451-.443-.59A4.5 4.5 0 0 1 3.5 3V2h-1a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-1v1a4.5 4.5 0 0 1-2.557 4.06c-.29.139-.443.377-.443.59v.7c0 .213.154.451.443.59A4.5 4.5 0 0 1 12.5 13v1h1a.5.5 0 0 1 0 1h-11zm2-13v1c0 .537.12 1.045.337 1.5h6.326c.216-.455.337-.963.337-1.5V2h-7zm3 6.35c0 .701-.478 1.236-1.011 1.492A3.5 3.5 0 0 0 4.5 13s.866-1.299 3-1.48V8.35zm1 0v3.17c2.134.181 3 1.48 3 1.48a3.5 3.5 0 0 0-1.989-3.158C8.978 9.586 8.5 9.052 8.5 8.351z" />
                    </svg>
                </div>

                <h2 class="fw-bold text-dark">Conta em Análise</h2>
                <p class="lead text-muted mt-3">
                    Obrigado por se registar como Vendedor no DCar Marketplace.
                </p>
                <p class="text-muted">
                    Para garantir a segurança da nossa plataforma, todos os vendedores novos requerem aprovação manual por parte da nossa equipa.
                </p>

                <div class="alert alert-light border mt-4">
                    <strong>Estado Atual:</strong> <span class="badge bg-warning text-dark">Pendente</span>
                </div>

                <p class="small text-muted mt-2">
                    Receberá uma notificação assim que a sua conta for ativada.
                </p>

                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">Voltar à Página Inicial</a>
                </div>
            </div>

        </div>
    </div>
</div>