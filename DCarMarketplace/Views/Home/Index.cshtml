@model IEnumerable<DCarMarketplace.Models.Anuncio>

@{
    ViewData["Title"] = "Home";
}

<div class="hero-section">
    <div class="container h-100">
        <div class="row h-100 align-items-center">
            <div class="col-md-7 col-lg-6">

                <div class="search-card shadow-lg p-4 bg-white rounded-4">
                    <form asp-controller="Anuncios" asp-action="Index" method="get">

                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted ms-1">Marca</label>
                                <select name="marca" id="searchMarca" class="form-select custom-select py-2">
                                    <option value="">Todas as Marcas</option>
                                    @if (ViewBag.ListaMarcas != null)
                                    {
                                        foreach (var marca in ViewBag.ListaMarcas)
                                        {
                                            <option value="@marca.Nome">@marca.Nome</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted ms-1">Modelo</label>
                                <select name="modelo" id="searchModelo" class="form-select custom-select py-2 bg-light text-muted" disabled>
                                    <option value="">Selecione a Marca</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col-6 col-md-3">
                                <label class="form-label small fw-bold text-muted ms-1">Preço até</label>
                                <select name="precoMax" class="form-select custom-select py-2 text-truncate">
                                    <option value="">Qualquer</option>
                                    <option value="5000">5.000€</option>
                                    <option value="10000">10.000€</option>
                                    <option value="20000">20.000€</option>
                                    <option value="30000">30.000€</option>
                                    <option value="50000">50.000€</option>
                                </select>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="form-label small fw-bold text-muted ms-1">Ano de</label>
                                <select name="anoMin" class="form-select custom-select py-2 text-truncate">
                                    <option value="">Qualquer</option>
                                    <option value="2015">2015</option>
                                    <option value="2018">2018</option>
                                    <option value="2020">2020</option>
                                    <option value="2022">2022</option>
                                </select>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="form-label small fw-bold text-muted ms-1">Segmento</label>
                                <select name="segmento" class="form-select custom-select py-2 text-truncate">
                                    <option value="">Todos</option>
                                    <option value="SUV">SUV</option>
                                    <option value="Sedan">Sedan</option>
                                    <option value="Citadino">Citadino</option>
                                    <option value="Comercial">Comercial</option>
                                    <option value="Desportivo">Desportivo</option>
                                </select>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="form-label small fw-bold text-muted ms-1">Combus</label>
                                <select name="combustivel" class="form-select custom-select py-2 text-truncate">
                                    <option value="">Todos</option>
                                    <option value="Diesel">Diesel</option>
                                    <option value="Gasolina">Gasolina</option>
                                    <option value="Elétrico">Elétrico</option>
                                    <option value="Híbrido">Híbrido</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <a href="@Url.Action("Index", "Anuncios")" class="text-dark small text-decoration-none d-flex align-items-center gap-2">
                                <i class="bi bi-sliders"></i> Pesquisa avançada
                            </a>
                            <button type="submit" id="btnVerAnuncios" class="btn btn-dcar px-5 py-2 fw-bold w-auto" style="border-radius: 8px;">
                                Ver Resultados
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Atualizar Contagem (Simplificado)
            function atualizarContagem() {
                $("#btnVerAnuncios").text("Ver Resultados");
            }
            atualizarContagem();

            // Quando a Marca muda
            $("#searchMarca").change(function () {
                var marcaSelecionada = $(this).val();
                var dropdownModelo = $("#searchModelo");
                dropdownModelo.empty();

                if (marcaSelecionada) {
                    dropdownModelo.append('<option value="">A carregar...</option>');
                    $.getJSON("/Anuncios/GetModelosByMarca", { nomeMarca: marcaSelecionada }, function (dados) {
                        dropdownModelo.empty();
                        dropdownModelo.append('<option value="">Modelo</option>');
                        $.each(dados, function (index, item) {
                            dropdownModelo.append('<option value="' + item.nome + '">' + item.nome + '</option>');
                        });
                        dropdownModelo.prop("disabled", false);
                        dropdownModelo.removeClass("bg-light text-muted");
                    });
                } else {
                    dropdownModelo.append('<option value="">Selecione a Marca</option>');
                    dropdownModelo.prop("disabled", true);
                    dropdownModelo.addClass("bg-light text-muted");
                }
                atualizarContagem();
            });

            $("#searchModelo").change(function () {
                atualizarContagem();
            });
        });
    </script>
}