@{
    ViewData["Title"] = "Contactos";
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Entre em <span class="text-danger">Contacto</span></h1>
        <p class="text-muted">Estamos aqui para ajudar. Escolha a forma mais conveniente.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 py-4 text-center rounded-4">
                <div class="card-body">
                    <div class="mb-3 text-danger"><i class="bi bi-geo-alt-fill fs-1"></i></div>
                    <h5 class="fw-bold">Morada</h5>
                    <p class="text-muted small">Quinta de Prados<br>5000-801 Vila Real, Portugal</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 py-4 text-center rounded-4">
                <div class="card-body">
                    <div class="mb-3 text-danger"><i class="bi bi-telephone-fill fs-1"></i></div>
                    <h5 class="fw-bold">Telefone</h5>
                    <p class="text-muted small">+351 259 350 000<br><span class="text-success">Disponível agora</span></p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 py-4 text-center rounded-4">
                <div class="card-body">
                    <div class="mb-3 text-danger"><i class="bi bi-envelope-fill fs-1"></i></div>
                    <h5 class="fw-bold">Email</h5>
                    <p class="text-muted small">geral@dcar-marketplace.pt<br>suporte@dcar.pt</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card bg-dark text-white rounded-4 shadow p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="fw-bold mb-1"><i class="bi bi-clock me-2"></i> Horário de Suporte</h4>
                        <p class="text-white-50 mb-0 small">A nossa equipa técnica está disponível:</p>
                    </div>
                    <div class="text-end">
                        <div class="fs-5 fw-bold">Segunda a Sexta</div>
                        <div class="text-danger fw-bold">09:00 - 18:00</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>