@{
    ViewData["Title"] = "Sobre Nós";
}

<div class="container mt-5 mb-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <img src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=800&q=80" class="img-fluid rounded-4 shadow" alt="Carro DCar">
        </div>
        <div class="col-md-6 ps-md-5">
            <h1 class="fw-bold mb-4">Sobre a <span class="text-danger">DCar</span></h1>
            <p class="lead text-muted">
                A DCar Marketplace é a plataforma de referência em Portugal para a compra e venda de veículos usados de confiança.
            </p>
            <p class="text-muted">
                Nascemos com a missão de simplificar o processo de venda automóvel, garantindo segurança, transparência e rapidez a todos os nossos utilizadores.
            </p>

            <div class="mt-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-danger bg-opacity-10 text-danger p-2 me-3"><i class="bi bi-shield-check fs-4"></i></div>
                    <div><strong>Segurança:</strong> Vendedores validados manualmente.</div>
                </div>
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-danger bg-opacity-10 text-danger p-2 me-3"><i class="bi bi-lightning-charge fs-4"></i></div>
                    <div><strong>Rapidez:</strong> Publique o seu anúncio em minutos.</div>
                </div>
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-danger bg-opacity-10 text-danger p-2 me-3"><i class="bi bi-people fs-4"></i></div>
                    <div><strong>Comunidade:</strong> Milhares de compradores ativos.</div>
                </div>
            </div>
        </div>
    </div>
</div>