@{
    ViewData["Title"] = "Termos e Políticas";
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Termos e <span class="text-danger">Políticas</span></h1>
        <p class="text-muted">Transparência total no nosso Marketplace.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-light p-3 me-3 text-danger">
                            <i class="bi bi-file-text fs-4"></i>
                        </div>
                        <h4 class="fw-bold mb-0">Termos de Serviço</h4>
                    </div>
                    <p class="text-muted small text-justify">
                        Ao utilizar o DCar Marketplace, concorda em cumprir os nossos termos.
                        A venda de veículos é da inteira responsabilidade dos utilizadores.
                        O DCar atua apenas como intermediário tecnológico.
                    </p>
                    <ul class="list-unstyled text-muted small mt-3">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Registo obrigatório para transações.</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Veracidade dos dados do anúncio.</li>
                        <li><i class="bi bi-check-circle-fill text-success me-2"></i> Comportamento ético na comunidade.</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-light p-3 me-3 text-danger">
                            <i class="bi bi-shield-lock fs-4"></i>
                        </div>
                        <h4 class="fw-bold mb-0">Política de Privacidade</h4>
                    </div>
                    <p class="text-muted small text-justify">
                        Respeitamos a sua privacidade. Os seus dados (email, telefone, NIF) são utilizados
                        exclusivamente para o funcionamento da plataforma e contacto entre comprador e vendedor.
                    </p>
                    <div class="alert alert-light border mt-3 mb-0 small">
                        <strong>RGPD:</strong> Pode solicitar a remoção dos seus dados a qualquer momento através do painel de perfil.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 bg-dark text-white mt-2">
                <div class="card-body p-4 d-md-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-1"><i class="bi bi-headset me-2"></i>Precisa de Ajuda?</h5>
                        <p class="mb-0 text-white-50 small">A nossa equipa de suporte está disponível para esclarecer dúvidas.</p>
                    </div>
                    <div class="mt-3 mt-md-0 text-end">
                        <div class="fw-bold fs-5">Segunda a Sexta</div>
                        <div class="text-danger fw-bold">09:00 - 18:00</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>