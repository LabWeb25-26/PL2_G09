@{
    ViewData["Title"] = "Novo Modelo";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-dark text-white fw-bold py-3 text-center">
                    <h5 class="mb-0">
                        Adicionar Modelo a <span class="text-danger fw-bolder">@ViewBag.MarcaNome</span>
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateModelo" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" name="marcaId" value="@ViewBag.MarcaId" />

                        <div class="form-floating mb-4">
                            <input type="text" name="nome" class="form-control" id="modeloNome" placeholder="Nome do Modelo" required autofocus />
                            <label for="modeloNome">Nome do Modelo (Ex: A3)</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold shadow-sm">Adicionar Modelo</button>
                            <a asp-action="GerirMarcas" class="btn btn-outline-secondary border-0">Voltar à Lista</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>