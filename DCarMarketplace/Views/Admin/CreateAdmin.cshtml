@model DCarMarketplace.Models.ViewModels.CriarAdminViewModel

@{
    ViewData["Title"] = "Novo Administrador";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-danger text-white py-3 rounded-top-4 text-center">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-shield-plus me-2"></i>Criar Novo Administrador</h4>
                </div>

                <div class="card-body p-4">
                    <p class="text-muted small text-center mb-4">
                        Crie uma nova conta com privilégios totais de gestão. <br>
                        <span class="text-danger fw-bold">Atenção:</span> Esta conta terá acesso a todo o backoffice.
                    </p>

                    <form asp-action="CreateAdmin">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger text-center"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Nome" class="form-control" placeholder="Nome" />
                            <label asp-for="Nome">Nome Completo</label>
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <label asp-for="Email">Email</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Password" class="form-control" placeholder="Password" />
                                    <label asp-for="Password">Password</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirmar" />
                                    <label asp-for="ConfirmPassword">Confirmar</label>
                                </div>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold">Criar Conta</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}