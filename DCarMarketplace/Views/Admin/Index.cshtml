@model IEnumerable<DCarMarketplace.Models.Utilizador>

@{
    ViewData["Title"] = "Gestão de Utilizadores";
}

<div class="container mt-4">
    <h2 class="mb-4 text-danger fw-bold"><i class="bi bi-shield-lock"></i> Backoffice</h2>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">Utilizadores Registados</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Nome / Email</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Aprovação</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@user.Nome</div>
                                <div class="text-muted small">@user.Email</div>
                            </td>
                            <td>
                                @if (user.Vendedor != null)
                                {
                                    <span class="badge bg-info text-dark">Vendedor</span>
                                }
                                else if (user.Comprador != null)
                                {

                                    <span class="badge bg-secondary">Comprador</span>
                                }
                                else
                                {

                                    <span class="badge bg-danger">Admin</span>
                                }
                            </td>
                            <td>
                                @if (user.EstadoConta == "ativo")
                                {
                                    <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill"></i> Ativo</span>
                                }
                                else
                                {
                                    <span class="text-danger small fw-bold"><i class="bi bi-ban"></i> Bloqueado</span>
                                }
                            </td>
                            <td>
                                @if (user.Vendedor != null)
                                {
                                    if (user.Vendedor.EstadoAprovacao == "pendente")
                                    {
                                        <span class="badge bg-warning text-dark">Pendente</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Aprovado</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    @if (user.Vendedor != null && user.Vendedor.EstadoAprovacao == "pendente")
                                    {
                                        <form asp-action="AprovarVendedor" method="post">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-success" title="Aprovar">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }

                                    @if (user.UserName != User.Identity.Name)
                                    {
                                        <form asp-action="AlternarBloqueio" method="post">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            @if (user.EstadoConta == "ativo")
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Bloquear">
                                                    <i class="bi bi-lock-fill"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Desbloquear">
                                                    <i class="bi bi-unlock-fill"></i>
                                                </button>
                                            }
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>