@model IEnumerable<DCarMarketplace.Models.Marca>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">Gestão de Marcas</h2>
            <p class="text-muted mb-0">Administre a lista completa de marcas e modelos.</p>
        </div>
        <button type="button" class="btn btn-danger btn-lg shadow-sm fw-bold" data-bs-toggle="modal" data-bs-target="#modalNovaMarca">
            <i class="bi bi-plus-lg me-2"></i> Nova Marca
        </button>
    </div>
                                                                                                                                                                                     
    @* Alertas de Feedback *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var marca in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100 rounded-4">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                            <h5 class="fw-bold mb-0">@marca.Nome</h5>
                            <span class="badge bg-danger">@marca.Modelos.Count</span>
                        </div>
                        <div class="card-body bg-light" style="max-height: 250px; overflow-y: auto;">
                            <ul class="list-group list-group-flush small">
                                @foreach (var mod in marca.Modelos.OrderBy(m => m.Nome))
                                {
                                    <li class="list-group-item bg-white d-flex justify-content-between align-items-center">
                                        <span>@mod.Nome</span>
                                        <form asp-action="ApagarModelo" asp-route-id="@mod.Id" method="post" onsubmit="return confirm('Apagar o modelo @mod.Nome?')">
                                            <button type="submit" class="btn btn-link text-muted p-0"><i class="bi bi-x-lg"></i></button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                        <div class="card-footer bg-white border-0 p-3">
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-outline-dark btn-sm fw-bold rounded-pill"
                                        data-bs-toggle="modal" data-bs-target="#modalNovoModelo"
                                        data-marcaid="@marca.Id" data-marcanome="@marca.Nome">
                                    <i class="bi bi-plus-circle me-1"></i> Adicionar Modelo
                                </button>
                                <form asp-action="ApagarMarca" asp-route-id="@marca.Id" method="post" onsubmit="return confirm('Apagar tudo?')">
                                    <button type="submit" class="btn btn-link btn-sm text-muted w-100 text-decoration-none">Apagar Marca</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="modalNovaMarca" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">Nova Marca</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateMarca" method="post">
                <div class="modal-body px-4">
                    <input name="nome" type="text" class="form-control" placeholder="Nome da marca" required />
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="submit" class="btn btn-danger fw-bold w-100">Guardar Marca</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNovoModelo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">Novo Modelo para <span id="labelMarca" class="text-danger"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateModelo" method="post">
                <div class="modal-body px-4">
                    <input type="hidden" name="marcaId" id="hiddenMarcaId" />
                    <input name="nome" type="text" class="form-control" placeholder="Nome do modelo" required />
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="submit" class="btn btn-danger fw-bold w-100">Adicionar Modelo</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lógica para injetar o ID da marca correta no modal de modelos
        var modalModelo = document.getElementById('modalNovoModelo');
        modalModelo.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('hiddenMarcaId').value = button.getAttribute('data-marcaid');
            document.getElementById('labelMarca').textContent = button.getAttribute('data-marcanome');
        });
    </script>
}