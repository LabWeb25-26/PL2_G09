@model DCarMarketplace.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Painel de Administração";
}

<div class="container mt-5 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-danger mb-0"><i class="bi bi-speedometer2"></i> Dashboard</h2>
            <p class="text-muted">Visão geral do sistema em tempo real.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-dark">
            <i class="bi bi-people"></i> Gerir Utilizadores
        </a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-5 border-primary rounded-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small text-uppercase mb-1 fw-bold">Utilizadores</p>
                            <h2 class="mb-0 fw-bold text-primary">@Model.TotalUtilizadores</h2>
                        </div>
                        <div class="text-primary opacity-25"><i class="bi bi-people-fill fs-1"></i></div>
                    </div>
                    <div class="mt-3 small text-muted">
                        <span><i class="bi bi-shop"></i> @Model.TotalVendedores Vendedores</span> •
                        <span><i class="bi bi-person"></i> @Model.TotalCompradores Compradores</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-5 border-success rounded-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small text-uppercase mb-1 fw-bold">Anúncios Ativos</p>
                            <h2 class="mb-0 fw-bold text-success">@Model.AnunciosAtivos</h2>
                        </div>
                        <div class="text-success opacity-25"><i class="bi bi-car-front-fill fs-1"></i></div>
                    </div>
                    <div class="mt-3 small text-muted">
                        Veículos disponíveis para venda no site.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-5 border-warning rounded-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small text-uppercase mb-1 fw-bold">Veículos Vendidos</p>
                            <h2 class="mb-0 fw-bold text-warning">@Model.AnunciosVendidos</h2>
                        </div>
                        <div class="text-warning opacity-25"><i class="bi bi-tag-fill fs-1"></i></div>
                    </div>
                    <div class="mt-3 small text-muted">
                        Total acumulado de vendas na plataforma.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 border-start border-5 border-danger rounded-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small text-uppercase mb-1 fw-bold">Volume Transacionado</p>
                            <h3 class="mb-0 fw-bold text-danger">@Model.ValorTotalTransacionado.ToString("N0") €</h3>
                        </div>
                        <div class="text-danger opacity-25"><i class="bi bi-currency-euro fs-1"></i></div>
                    </div>
                    <div class="mt-3 small text-muted">
                        Valor estimado de transações.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0">Top 5 Marcas Populares</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Marca</th>
                                <th class="text-end pe-4">Anúncios / Vendas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopMarcas.Any())
                            {
                                foreach (var item in Model.TopMarcas)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">@item.Key</td>
                                        <td class="text-end pe-4"><span class="badge bg-dark rounded-pill">@item.Value</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" class="text-center py-4 text-muted">Sem dados suficientes.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>