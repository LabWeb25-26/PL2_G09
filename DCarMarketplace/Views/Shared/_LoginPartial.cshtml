@using Microsoft.AspNetCore.Identity
@using DCarMarketplace.Models

@inject SignInManager<Utilizador> SignInManager
@inject UserManager<Utilizador> UserManager

<ul class="navbar-nav align-items-center gap-3">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item d-flex align-items-center">
            <a class="text-decoration-none text-secondary fw-500 d-flex align-items-center gap-2"
               asp-controller="Favoritos"
               asp-action="Index">

                <i class="bi bi-heart-fill text-secondary fs-5"></i>
                <span>Favoritos <span id="fav-count">(0)</span></span>
            </a>
        </li>

        <li class="nav-item d-none d-md-block" style="height: 25px; border-right: 1px solid #ddd;"></li>

        <li class="nav-item dropdown">
            <a class="nav-link text-secondary dropdown-toggle d-flex align-items-center gap-2 p-0" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person fs-4"></i>
                <span class="fw-500">@(User.Identity.Name?.Split('@')[0])</span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-3 p-2 rounded-3">
                <li>
                    <a class="dropdown-item rounded-2 mb-1" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="bi bi-person-gear me-2"></i> Perfil
                    </a>
                </li>

                @if (User.IsInRole("Vendedor"))
                {
                    <li><hr class="dropdown-divider"></li>
                    <li><h6 class="dropdown-header text-uppercase small fw-bold">Gestão de Vendas</h6></li>

                    <li>
                        <a class="dropdown-item rounded-2 mb-1" asp-controller="Anuncios" asp-action="MeusAnuncios">
                            <i class="bi bi-car-front-fill me-2 text-primary"></i> Todos os Anúncios
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item rounded-2 mb-1" asp-controller="Anuncios" asp-action="VeiculosReservados">
                            <i class="bi bi-clock-history me-2 text-info"></i> Reservados
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item rounded-2 mb-1" asp-controller="Anuncios" asp-action="VeiculosVendidos">
                            <i class="bi bi-tag-fill me-2 text-danger"></i> Vendidos
                        </a>
                    </li>
                }

                <li><hr class="dropdown-divider"></li>
                <li>
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item text-danger rounded-2">
                            <i class="bi bi-box-arrow-right me-2"></i> Sair
                        </button>
                    </form>
                </li>
            </ul>
        </li>

        @if (User.IsInRole("Vendedor"))
        {
            <li class="nav-item ms-2">
                <a class="btn btn-dcar text-white d-flex align-items-center gap-2 px-4 py-2 shadow-sm"
                   asp-controller="Anuncios" asp-action="Create">
                    <i class="bi bi-plus-lg" style="font-size: 1.1rem;"></i>
                    Começar a vender
                </a>
            </li>
        }
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark fw-bold d-flex align-items-center gap-2" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-person-circle fs-4"></i>
                <span>Login | Criar Conta</span>
            </a>
        </li>
        <li class="nav-item ms-2">
            <a class="btn btn-dcar text-white fw-bold px-4" asp-area="Identity" asp-page="/Account/Login">
                Vender Carro
            </a>
        </li>
    }
</ul>