<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DCar Marketplace</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DCarMarketplace.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo-dcar.png" alt="DCar Marketplace" style="height: 45px; width: auto;" />
                </a>
                                                                                                                                                                                    
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1 align-items-center">

                       

                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown ms-2">
                                <a class="nav-link dropdown-toggle text-danger fw-bold" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock"></i> Backoffice
                                </a>
                                <ul class="dropdown-menu border-0 shadow" aria-labelledby="adminDropdown">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-people me-2"></i> Gerir Utilizadores</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="GerirMarcas"><i class="bi bi-tags me-2"></i> Gerir Marcas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Historico"><i class="bi bi-clock-history me-2"></i> Histórico de Ações</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav flex-grow-1 align-items-center">
                    </ul>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @await Component.InvokeAsync("Notificacoes")
                    }

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0 flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-4 text-center bg-dark text-white border-top border-danger border-3">
        <div class="container">
            <div class="row align-items-center">

                <div class="col-md-3 text-md-start mb-3 mb-md-0">
                    <a asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo-dcar.png" alt="DCar" style="height: 50px; filter: brightness(0) invert(1);" />
                    </a>
                </div>

                <div class="col-md-6 mb-3 mb-md-0">
                    <a asp-controller="Home" asp-action="Sobre" class="footer-link mx-2 text-white text-decoration-none fw-bold">Sobre</a> /
                    <a asp-controller="Home" asp-action="Termos" class="footer-link mx-2 text-white text-decoration-none fw-bold">Termos</a> /
                    <a asp-controller="Home" asp-action="Contactos" class="footer-link mx-2 text-white text-decoration-none fw-bold">Contactos</a>
                </div>

                <div class="col-md-3 text-md-end">
                    <small class="text-white-50">&copy; 2025 DCar Marketplace</small>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
            if ($("#fav-count").length) {
                $.get("/Favoritos/GetTotal", function(total) {
                    $("#fav-count").text("(" + total + ")");
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>