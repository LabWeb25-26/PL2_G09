@model IEnumerable<DCarMarketplace.Models.Marca>

@{
    ViewData["Title"] = "Marcas Favoritas";
    var seguidas = ViewBag.MarcasSeguidas as List<int> ?? new List<int>();
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4">📢 Alertas de Marcas</h2>
    <p class="text-muted">Selecione as marcas que lhe interessam para receber notificações de novos anúncios.</p>

    <div class="row g-3 mt-3">
        @foreach (var marca in Model)
        {
            bool isFollowing = seguidas.Contains(marca.Id);
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">@marca.Nome</h5>
                        <button class="btn btn-sm rounded-circle @(isFollowing ? "btn-danger" : "btn-outline-secondary")"
                                onclick="toggleMarca(@marca.Id, this)" title="Seguir Marca">
                            <i class="bi @(isFollowing ? "bi-bell-fill" : "bi-bell")"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleMarca(id, btn) {
            $.post("/Comprador/ToggleMarca", { id: id }, function (res) {
                if (res.success) {
                    var icon = $(btn).find("i");
                    if (res.seguindo) {
                        $(btn).removeClass("btn-outline-secondary").addClass("btn-danger");
                        icon.removeClass("bi-bell").addClass("bi-bell-fill");
                    } else {
                        $(btn).removeClass("btn-danger").addClass("btn-outline-secondary");
                        icon.removeClass("bi-bell-fill").addClass("bi-bell");
                    }
                }
            });
        }
    </script>
}