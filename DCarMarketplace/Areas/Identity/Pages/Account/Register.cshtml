@page
@model RegisterModel
@{
    ViewData["Title"] = "Registar";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registar - DCar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-body">

    <div class="login-card">
        <img src="~/images/logo-dcar.png" alt="DCar Logo" class="login-logo" />

        <div class="auth-tabs">
            <a asp-page="./Login" class="auth-tab">Entrar</a>
            <a href="#" class="auth-tab active">Criar Conta</a>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3"></div>

            <div class="account-type-selector">
                <input type="radio" asp-for="Input.TipoConta" value="Comprador" id="type-buyer" checked>
                <label for="type-buyer">Comprador</label>

                <input type="radio" asp-for="Input.TipoConta" value="Vendedor" id="type-seller">
                <label for="type-seller">Vendedor</label>
            </div>

            <div class="custom-input-group">
                <input asp-for="Input.Nome" placeholder="Nome Completo" />
                <i class="bi bi-person input-icon"></i>
            </div>
            <span asp-validation-for="Input.Nome" class="text-danger small d-block mb-2"></span>

            <div class="custom-input-group">
                <input asp-for="Input.Email" placeholder="Email" />
                <i class="bi bi-envelope input-icon"></i>
            </div>
            <span asp-validation-for="Input.Email" class="text-danger small d-block mb-2"></span>

            <div class="custom-input-group">
                <input asp-for="Input.Password" placeholder="Password" type="password" />
                <i class="bi bi-lock input-icon"></i>
            </div>

            <div class="custom-input-group">
                <input asp-for="Input.ConfirmPassword" placeholder="Confirmar Password" type="password" />
                <i class="bi bi-lock-fill input-icon"></i>
            </div>
            <span asp-validation-for="Input.Password" class="text-danger small d-block mb-2"></span>

            <div class="row g-2">
                <div class="col-6">
                    <div class="custom-input-group mb-0">
                        <input asp-for="Input.Contactos" placeholder="Telemóvel" />
                    </div>
                </div>
                <div class="col-6">
                    <div class="custom-input-group mb-0">
                        <input asp-for="Input.NIF" placeholder="NIF" />
                    </div>
                </div>
            </div>
            <div class="custom-input-group mt-3">
                <input asp-for="Input.Morada" placeholder="Morada" />
                <i class="bi bi-geo-alt input-icon"></i>
            </div>

            <button id="registerSubmit" type="submit" class="btn-dcar">REGISTAR</button>
        </form>
    </div>

</body>
</html>