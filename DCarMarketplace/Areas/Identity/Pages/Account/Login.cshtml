@page
@model LoginModel
@{
    ViewData["Title"] = "Entrar";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - DCar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-body">

    <div class="login-card">
        <img src="~/images/logo-dcar.png" alt="DCar Logo" class="login-logo" />

        <div class="auth-tabs">
            <a href="#" class="auth-tab active">Entrar</a>
            <a asp-page="./Register" class="auth-tab">Criar Conta</a>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3"></div>

            <div class="custom-input-group">
                <input asp-for="Input.Email" placeholder="Email" />
                <i class="bi bi-envelope input-icon"></i>
            </div>
            <span asp-validation-for="Input.Email" class="text-danger small d-block mb-2"></span>

            <div class="custom-input-group">
                <input asp-for="Input.Password" placeholder="Password" type="password" />
                <i class="bi bi-lock input-icon"></i>
            </div>
            <span asp-validation-for="Input.Password" class="text-danger small d-block mb-2"></span>

            <div class="login-footer-links">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">
                        Lembrar de mim
                    </label>
                </div>
                <a id="forgot-password" asp-page="./ForgotPassword" style="font-size: 0.8rem;">Esqueceu-se da sua password?</a>
            </div>

            <button id="login-submit" type="submit" class="btn-dcar">ENTRAR</button>
        </form>
    </div>

</body>
</html>