@page
@model IndexModel
@{
    ViewData["Title"] = "Perfil";
    var username = User.Identity.Name;
    var iniciais = "U";
    if (!string.IsNullOrEmpty(username) && username.Contains("@"))
    {
        iniciais = username.Substring(0, 2).ToUpper();
    }
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4 d-flex align-items-center">
        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-4"
             style="width: 80px; height: 80px; font-size: 2rem; font-weight: bold;">
            @iniciais
        </div>

        <div class="flex-grow-1">
            <h3 class="mb-1 fw-bold">@username</h3>
            <p class="text-muted mb-0">
                <i class="bi bi-envelope"></i> @username &nbsp;|&nbsp;
                <i class="bi bi-calendar3"></i> Membro do DCar
            </p>
        </div>

        <a asp-page="./ChangePassword" class="btn btn-outline-primary">
            <i class="bi bi-key"></i> Mudar Password
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body p-2">
        <nav class="nav nav-pills nav-fill">
            <a class="nav-link active bg-white text-primary shadow-sm" href="#">
                <i class="bi bi-person"></i> Definições
            </a>

            @if (User.IsInRole("Vendedor"))
            {
                <a class="nav-link text-muted" asp-controller="Anuncios" asp-action="MeusAnuncios">
                    <i class="bi bi-car-front"></i> Meus Anúncios
                </a>
            }

            <a class="nav-link text-muted" href="#"><i class="bi bi-heart"></i> Favoritos</a>
            <a class="nav-link text-muted" href="#"><i class="bi bi-clock-history"></i> Histórico</a>
        </nav>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h4 class="mb-3 fw-bold">Informações Pessoais</h4>
        <partial name="_StatusMessage" model="Model.StatusMessage" />

        <form id="profile-form" method="post">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Username" class="form-label fw-bold">Email / Username</label>
                    <input asp-for="Username" class="form-control bg-light" disabled />
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.PhoneNumber" class="form-label fw-bold">Telefone</label>
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="+351..." />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Localização</label>
                <input type="text" class="form-control" placeholder="A sua morada..." />
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-primary px-4 py-2">
                Guardar Alterações
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}