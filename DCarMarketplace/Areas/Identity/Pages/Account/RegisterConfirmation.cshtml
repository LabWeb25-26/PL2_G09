@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirmar Registo";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5 text-center">

                    <h1 class="text-primary mb-3"><i class="bi bi-envelope-check-fill"></i> Verifique o seu e-mail</h1>

                    <p class="lead">Obrigado por se registar no <strong>DCar Marketplace</strong>.</p>
                    <hr class="my-4">

                    @if (Model.DisplayConfirmAccountLink)
                    {
                        @* Este bloco não será visível porque definimos a variável como false no .cs *@
                        <div class="alert alert-info mt-4">
                            <h5 class="fw-bold"><i class="bi bi-info-circle"></i> Ambiente de Desenvolvimento</h5>
                            <p class="mb-2">Use o link abaixo para confirmar a conta:</p>
                            <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-primary fw-bold px-4 py-2">
                                Confirmar Email Agora
                            </a>
                        </div>
                    }
                    else
                    {
                        @* Esta é a mensagem que o utilizador verá agora *@
                        <div class="py-3">
                            <p class="fs-5">Enviámos um link de confirmação para o endereço: <br><strong>@Model.Email</strong></p>
                            <p class="text-muted">Por favor, clique no link dentro da mensagem para validar a sua conta e conseguir efetuar login.</p>
                        </div>

                        <div class="mt-4">
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary">
                                Voltar ao Login
                            </a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>