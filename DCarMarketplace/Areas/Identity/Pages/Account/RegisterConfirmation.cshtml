@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirmação de Registo";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5 text-center">

                    <h1 class="text-success mb-3"><i class="bi bi-check-circle-fill"></i> Registo Efetuado!</h1>

                    <p class="lead">Obrigado por se registar no DCar Marketplace.</p>

                    @if (Model.DisplayConfirmAccountLink)
                    {
                        <div class="alert alert-info mt-4">
                            <h5 class="fw-bold"><i class="bi bi-info-circle"></i> Ambiente de Desenvolvimento</h5>
                            <p class="mb-2">Como não existe um servidor de email configurado, use o link abaixo para confirmar a conta:</p>

                            <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-primary fw-bold px-4 py-2">
                                Clique aqui para confirmar o seu email
                            </a>
                        </div>
                    }
                    else
                    {
                        <p>Por favor, verifique a sua caixa de email para confirmar a sua conta.</p>
                    }

                </div>
            </div>
        </div>
    </div>
</div>